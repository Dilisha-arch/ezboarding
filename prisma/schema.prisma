enum RentNegotiability {
  FIXED
  NEGOTIABLE
}

enum FurnitureStatus {
  FURNISHED
  UNFURNISHED
}

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  LANDLORD
  ADMIN
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
  SUSPENDED
}

enum PropertyType {
  BOARDING_ROOM
  HOSTEL
  ANNEX
  HOUSE
}

enum GenderRestriction {
  BOYS_ONLY
  GIRLS_ONLY
  NO_RESTRICTION
}

enum OccupancySetup {
  SINGLE
  SHARED
}

enum BathroomType {
  ATTACHED
  SHARED
}

enum AdminActionType {
  SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
  RESUBMITTED
  REACTIVATED
}

// ==========================================
// AUTH.JS v5 MODELS & USERS
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  role          Role      @default(LANDLORD)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  adminActions  AdminAction[] @relation("AdminUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// DOMAIN MODELS: BODIM.LK
// ==========================================

model Property {
  id                String            @id @default(cuid())
  title             String
  description       String            @db.Text
  status            PropertyStatus    @default(PENDING)
  propertyType      PropertyType
  
  // Step 2: Pricing
  pricePerMonth     Int
  rentNegotiable    RentNegotiability @default(FIXED)
  keyMoneyMonths    Int               @default(0)
  utilitiesIncluded Boolean           @default(false)
  
  // Step 3: Location
  address           String            @db.Text
  googleMapsUrl   String?
  lat               Float?
  lng               Float?
  
  // Step 4: Layout & Physical
  totalRooms        Int
  totalBathrooms    Int
  genderRestriction GenderRestriction
  occupancySetup    OccupancySetup
  bedsPerRoom       Int?              // Only if SHARED
  bathroomType      BathroomType
  
  // Spots for search engine logic
  totalSpots        Int
  availableSpots    Int
  
  // Step 5: Amenities & Rules
  furnitureStatus   FurnitureStatus   @default(UNFURNISHED)
  mealsIncluded     Boolean           @default(false)
  houseRules        String?           @db.Text
  
  // Step 6: Contact
  contactNumber     String
  isWhatsApp        Boolean           @default(false)
  
  // System fields
  views             Int               @default(0)
  inquiryClicks     Int               @default(0)
  rejectionReason   String?           @db.Text

  landlordId        String
  landlord          User              @relation(fields: [landlordId], references: [id])
  
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  images             PropertyImage[]
  nearbyUniversities PropertyUniversity[]
  amenities          PropertyAmenity[]
  adminActions       AdminAction[]

  @@index([landlordId, status, deletedAt])
  @@index([status, createdAt])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  order      Int
  
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// ==========================================
// MASTER DATA (Seeded)
// ==========================================

model University {
  id         String   @id @default(cuid())
  name       String   @unique
  shortName  String
  slug       String   @unique
  city       String
  district   String
  gateLat    Float
  gateLng    Float
  isActive   Boolean  @default(true)

  faculties          Faculty[]
  nearbyProperties   PropertyUniversity[]
}

model Faculty {
  id           String   @id @default(cuid())
  name         String
  shortName    String
  slug         String   @unique
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  nearbyProperties PropertyUniversity[]
}

model Amenity {
  id         String   @id @default(cuid())
  name       String   @unique
  icon       String
  category   String

  properties PropertyAmenity[]
}

// ==========================================
// JUNCTION TABLES
// ==========================================

model PropertyUniversity {
  propertyId   String
  universityId String
  facultyId    String?
  distanceKm   Float

  property     Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  faculty      Faculty?   @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@id([propertyId, universityId])
  @@index([universityId, distanceKm])
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
}

// ==========================================
// AUDIT LOG
// ==========================================

model AdminAction {
  id         String          @id @default(cuid())
  action     AdminActionType
  adminId    String?         
  propertyId String
  note       String?         @db.Text
  createdAt  DateTime        @default(now())

  admin      User?           @relation("AdminUser", fields: [adminId], references: [id])
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}
